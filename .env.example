# Copy this file to .env and fill in your values.
# .env is never committed — see .gitignore.

# --- Provider selection ---

# Which AI provider to use: gemini, azure, or mock
# "mock" returns a canned transcript instantly — no API keys required, useful for UI testing
# PROVIDER=gemini
PROVIDER=azure

# --- OBS (required for all providers) ---

# OBS WebSocket password (Tools → WebSocket Server Settings in OBS)
OBS_PASSWORD=

# OBS WebSocket host/port (default: localhost:4455)
# OBS_HOST=localhost
# OBS_PORT=4455

# --- Gemini (required when PROVIDER=gemini) ---

# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# --- Azure (required when PROVIDER=azure) ---

# Azure AI Speech - for transcription + speaker diarization
# Create a Speech resource in Azure Portal (Cognitive Services → Speech)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure OpenAI - for summarization and speaker name enrichment
# Create an Azure OpenAI resource and deploy a chat-completions model (e.g. gpt-5.2)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- Storage (optional) ---

# Directories for recordings, transcripts, and summaries (defaults shown)
# RECORDINGS_DIR=./data/audio
# TRANSCRIPTS_DIR=./data/transcripts
# SUMMARIES_DIR=./data/summaries

# Web server port (default: 8080)
# PORT=8080

# --- Confluence export (optional) ---

# Atlassian Cloud API token: https://id.atlassian.com/manage-profile/security/api-tokens
# CONFLUENCE_URL=https://yourcompany.atlassian.net
# CONFLUENCE_EMAIL=you@yourcompany.com
# CONFLUENCE_TOKEN=
# CONFLUENCE_SPACE_KEY=
# CONFLUENCE_PARENT_PAGE_ID=

# --- Notion export (optional) ---

# Notion Integration Token: https://www.notion.so/profile/integrations
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# --- Export options ---

# Set to "true" to include the full transcript in Confluence/Notion exports.
# Default is false — only the summary is exported.
# EXPORT_INCLUDE_TRANSCRIPT=false
